#!/usr/bin/env bash

# NOTE: The following packages are handled by justfile recipes (just install) in the dotfiles repository:
# Core tools: git, curl, stow, vim, neovim, tmux, zsh, fzf, fd, ripgrep, xclip, wl-clipboard
# Development: nodejs, npm, python, build tools, cmake
# CLI tools: eza, bat, git-delta, zoxide, starship, btop, entr, jq, thefuck, tldr
# Utilities: ffmpeg, p7zip, poppler, imagemagick
# DevOps: tfswitch (terraform versions), ansible-core, kubectl, helm
# Shell: zsh-plugins, atuin history import, shell switching
# Applications: lazygit, yazi, atuin
# Font: JetBrainsMono Nerd Font (downloaded from nerd-fonts releases)
# Linters & formatters: installed in NeoVim via :MasonInstall shellcheck shfmt stylua prettier ruff hadolint tflint ansible-lint
# See: https://github.com/Aapok0/dotfiles
#
# Packages kept here are those needed BEFORE running justfile or not included in justfile
#
# Package source preference on Fedora:
#   1. Fedora official repos (dnf_packages, dnf_apps, dnf_gaming, dnf_kde)
#   2. RPM Fusion free / nonfree (rpmfusion_*_packages)
#   3. Flatpak (flatpak_apps) — preferred over COPR for desktop apps; updates via flatpak
#   4. COPR — avoid when a Flatpak or RPM Fusion package exists
#
# RPM Fusion:
#   free    — free software Fedora cannot ship (codec libs, some media players, etc.)
#   nonfree — proprietary/redistributable-but-not-open software (NVIDIA drivers, Steam, VirtualBox)

dnf_tools=(
    "dnf-plugins-core"
    "rpmconf"
    "needs-restarting"
)

