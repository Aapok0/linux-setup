#!/usr/bin/env bash
set -o pipefail

timestamp=$(date +"%Y-%m-%d_%H:%M:%S")
username="$(whoami)"
LOGFILE="logs/${timestamp}_setup.log"

mkdir -p logs
exec 1> >(tee -a "$LOGFILE") 2>&1

_log() {
    local level="$1" msg="$2"
    printf "[%s] %s: %s\n" "$(date '+%Y-%m-%d %H:%M:%S')" "$level" "$msg"
}

_info() {
    _log "INFO" "$*"
    sleep 2
}

_log "INFO" "LINUX SETUP SCRIPT FOR ARCH, DEBIAN AND FEDORA"; sleep 1

_get_distro() {
    [ -f /etc/os-release ] && source /etc/os-release
    [ "$1" = "arch" ] || [ "$1" = "debian" ] || [ "$1" = "fedora" ] && echo "$1" && return 0
    [[ "$ID" =~ "fedora" ]] || [[ "$ID_LIKE" =~ "fedora" ]] && echo "fedora" && return 0
    [[ "$ID_LIKE" =~ "arch" ]] || [[ "$ID" =~ "arch" ]] && echo "arch" && return 0
    [[ "$ID_LIKE" =~ "debian" ]] || [[ "$ID" =~ "debian" ]] && echo "debian" && return 0
    return 1
}

main() {
    distro=$(_get_distro "$1")
    if [ $? -ne 0 ] || [ -z "$distro" ]; then
        _log "ERROR" "Unknown distribution. Provide 'arch', 'debian', or 'fedora' as an argument."
        exit 1
    fi

    _info "Running setup for $distro..."
    LOGFILE="$LOGFILE" scripts/setup-$distro $username
    
    if [ $? -eq 0 ]; then
        _log "INFO" "Setup completed. Log saved to: $LOGFILE"
        echo ""
        echo "SETUP FINISHED"
        echo "Post-setup tasks:"
        echo "1. Reboot the machine"
        echo "2. Run ghostty"
        echo "3. Check firewall rules if one was already installed"
        echo "4. Install nvm and node:"
        echo "   - Get install command from: https://github.com/nvm-sh/nvm#installing-and-updating"
        echo "   - exec zsh"
        echo "   - nvm install node"
        echo "5. Install python with pyenv (skip first two steps on arch):"
        echo "   - pyenv install -l | less"
        echo "   - pyenv install <version>"
        echo "   - pyenv global <version>"
        echo "   - mkdir -p ~/Python && cd ~/Python"
        echo "   - python -m venv <name>"
        echo "6. Open nvim and install plugins:"
        echo "   - nvim"
        echo "   - Let lazy.nvim install plugins"
        echo "   - :MasonInstall shellcheck shfmt stylua prettier ruff hadolint tflint ansible-lint"
        echo "7. Open tmux (tmux) and install plugins (ctrl+space I)"
        exit 0
    else
        _log "ERROR" "Setup interrupted by unexpected error"
        exit 1
    fi
}

main "$@"
