#!/usr/bin/env bash

# Exit codes:
#   0 - success
#   1 - error
#   2 - user cancelled

set -uo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck source=lib/common.sh
source "${REPO_ROOT}/scripts/lib/common.sh"
init_logging "setup"

source "${REPO_ROOT}/vars/arch-vars"
USERNAME=$1
SETUP_UFW=true
SETUP_BTRFS_SNAPPER=true

_pkg_is_installed() {
    paru -Qs "$1" | grep -q "local.*$1 "
}

_install_pkg() {
    _pkg_is_installed "$1" && {
        _info "Package $1 already installed"
        return 0
    }
    _info "Installing $1"
    _echo_run paru "${2:---skipreview --noconfirm}" -S "$1"
}

_install_packages() {
    local category="$1"
    shift
    local packages=("$@")
    [ -n "$category" ] && [ "$category" != "." ] && _info "Installing $category..."
    for pkg in "${packages[@]}"; do
        _pkg_is_installed "$pkg" && {
            _info "Package $pkg already installed"
            continue
        }
        _out "Installing $pkg"
        _echo_run paru --skipreview -S "$pkg"
    done
}

# ---------------------------------------------------------------------------
# Btrfs + Snapper (Arch Wiki suggested layout)
# ---------------------------------------------------------------------------

_is_btrfs() {
    local path="${1:-/}"
    findmnt -n -o FSTYPE "$path" 2>/dev/null | grep -qx btrfs
}

_setup_bootbackup_hooks() {
    local hooks_dir="${REPO_ROOT}/config/arch/pacman/hooks"
    local hook

    [ -d "$hooks_dir" ] || {
        _error "Missing ${hooks_dir}"
        return 1
    }

    _info "Installing /boot backup pacman hooks (→ /.bootbackup)..."
    for hook in 55-bootbackup_pre.hook 95-bootbackup_post.hook; do
        [ -f "${hooks_dir}/${hook}" ] || {
            _error "Missing ${hooks_dir}/${hook}"
            return 1
        }
        _echo_run sudo install -Dm644 "${hooks_dir}/${hook}" "/etc/pacman.d/hooks/${hook}"
    done
}

_setup_snapper_updatedb() {
    if grep -q '^PRUNENAMES' /etc/updatedb.conf; then
        grep -q '\.snapshots' /etc/updatedb.conf && return 0
        _echo_run sudo sed -i 's|^PRUNENAMES *= *"|PRUNENAMES = ".snapshots |' /etc/updatedb.conf
    else
        _echo_run bash -c "echo 'PRUNENAMES = \".snapshots\"' | sudo tee -a /etc/updatedb.conf"
    fi
}

_snapper_config_exists() {
    local config="$1"
    [ -f "/etc/snapper/configs/${config}" ]
}

_setup_snapper_config_for_mount() {
    local config="$1"
    local mount_path="$2"
    local snapshots_mount="$3"

    if _snapper_config_exists "$config"; then
        _info "Snapper config '${config}' already present"
        return 0
    fi

    _info "Creating Snapper config '${config}' for ${mount_path}..."

    if mountpoint -q "$snapshots_mount" 2>/dev/null; then
        _echo_run sudo umount "$snapshots_mount"
    fi
    if [ -e "$snapshots_mount" ]; then
        _echo_run sudo rm -rf "$snapshots_mount"
    fi

    _echo_run sudo snapper -c "$config" create-config "$mount_path"

    if sudo btrfs subvolume show "$snapshots_mount" &>/dev/null; then
        _echo_run sudo umount "$snapshots_mount" 2>/dev/null || true
        _echo_run sudo btrfs subvolume delete "$snapshots_mount"
    fi

    _echo_run sudo mkdir -p "$snapshots_mount"
    _echo_run sudo mount -a
    _echo_run sudo chmod 750 "$snapshots_mount"
}

_setup_snapper_configs() {
    _setup_snapper_config_for_mount root / /.snapshots

    if _is_btrfs /home; then
        _setup_snapper_config_for_mount home /home /home/.snapshots
    fi

    _echo_run sudo snapper -c root set-config "ALLOW_USERS=${USERNAME}" SYNC_ACL=yes

    if _is_btrfs /home && _snapper_config_exists home; then
        _echo_run sudo snapper -c home set-config \
            "ALLOW_USERS=${USERNAME}" SYNC_ACL=yes TIMELINE_CREATE=no
    fi
}

_setup_snapper_rollback() {
    local src="${REPO_ROOT}/config/arch/snapper-rollback.conf"
    local root_src tmp

    _install_pkg "snapper-rollback" "--skipreview --noconfirm"

    [ -f "$src" ] || {
        _warn "Missing ${src}; configure /etc/snapper-rollback.conf manually"
        return 0
    }

    if [ -f /etc/snapper-rollback.conf ]; then
        _info "snapper-rollback.conf already present"
        return 0
    fi

    root_src=$(findmnt -n -o SOURCE / 2>/dev/null || true)
    root_src=${root_src%%\[*}

    _info "Installing /etc/snapper-rollback.conf (dev=${root_src:-unset})..."
    tmp=$(mktemp)
    sed "s|^#dev = .*|dev = ${root_src}|" "$src" >"$tmp"
    if [ -z "$root_src" ]; then
        _warn "Could not detect btrfs device for / — edit dev= in /etc/snapper-rollback.conf"
    fi
    _echo_run sudo install -Dm644 "$tmp" /etc/snapper-rollback.conf
    rm -f "$tmp"
}

_setup_mkinitcpio_overlayfs() {
    if grep -q 'grub-btrfs-overlayfs' /etc/mkinitcpio.conf 2>/dev/null; then
        _info "mkinitcpio grub-btrfs-overlayfs hook already configured"
        return 0
    fi

    if grep -qE 'HOOKS=.*systemd' /etc/mkinitcpio.conf 2>/dev/null; then
        _warn "mkinitcpio uses systemd hook — grub-btrfs-overlayfs requires udev (see Arch Wiki Snapper)"
    fi

    _info "Adding grub-btrfs-overlayfs hook to mkinitcpio.conf..."
    _echo_run sudo cp /etc/mkinitcpio.conf /etc/mkinitcpio.conf.bkp
    _echo_run sudo sed -i 's/\(HOOKS=(.*\))/\1 grub-btrfs-overlayfs)/' /etc/mkinitcpio.conf
    _echo_run sudo mkinitcpio -P
}

_setup_grub_btrfs() {
    if systemctl is-enabled grub-btrfsd.service &>/dev/null; then
        _info "grub-btrfsd already enabled"
    else
        _info "Enabling grub-btrfsd (watches /.snapshots, updates GRUB menu)..."
        local dropin_dir="/etc/systemd/system/grub-btrfsd.service.d"
        _echo_run sudo mkdir -p "$dropin_dir"
        _echo_run sudo tee "${dropin_dir}/override.conf" >/dev/null <<'EOF'
[Service]
ExecStart=
ExecStart=/usr/bin/grub-btrfsd --syslog /.snapshots
EOF
        _echo_run sudo systemctl daemon-reload
        _echo_run sudo systemctl enable --now grub-btrfsd.service
    fi

    if sudo test -f /boot/grub/grub.cfg; then
        _echo_run sudo grub-mkconfig -o /boot/grub/grub.cfg
    fi
}

_setup_snapper_timers() {
    _echo_run sudo systemctl enable --now snapper-timeline.timer
    _echo_run sudo systemctl enable --now snapper-cleanup.timer
}

_setup_btrfs_snapper() {
    [ "${SETUP_BTRFS_SNAPPER:-true}" = true ] || {
        _info "SETUP_BTRFS_SNAPPER=false; skipping Snapper setup"
        return 0
    }

    _is_btrfs / || {
        _info "Root is not btrfs; skipping Snapper setup"
        return 0
    }

    _info "Btrfs root detected; configuring Snapper rollback support (Phase 1)..."

    _setup_bootbackup_hooks || return 1
    _setup_snapper_configs || return 1
    _setup_snapper_updatedb
    _setup_mkinitcpio_overlayfs
    _setup_grub_btrfs
    _setup_snapper_timers
    _setup_snapper_rollback

    _info "Snapper setup complete (verify: snapper list; paru -S htop)"
    _info "Rollback docs: instructions/install/arch-install.md#rollback-and-restore"
}

# ---------------------------------------------------------------------------
# Services
# ---------------------------------------------------------------------------

_setup_tailscale() {
    if command -v tailscale &>/dev/null; then
        _info "Tailscale already installed"
        _ensure_systemd_enabled_now tailscaled.service
        return 0
    fi

    _info "Setting up Tailscale (official extra repository)..."
    _install_pkg "tailscale" "--skipreview --noconfirm"
    _ensure_systemd_enabled_now tailscaled.service
    _info "Tailscale installed and configured"
    _info "Connect with: sudo tailscale up"
}

main() {
    SETUP_ERRORS=0
    _info "Setting up environment for an arch based distribution."

    _setup_wheel_nopasswd_sudo "$USERNAME"
    _ensure_ssh_ed25519_key

    _info "Converting linux-setup repository to SSH..."
    if [ -d "${REPO_ROOT}/.git" ]; then
        _set_ssh_remote "${REPO_ROOT}"
    fi

    _ensure_pacman_multilib
    _echo_run sudo pacman -Syy
    _info "Installing paru AUR helper..."
    if ! command -v paru &>/dev/null; then
        _echo_run cd "$HOME"
        _echo_run git clone https://aur.archlinux.org/paru.git
        _echo_run cd paru
        _echo_run sudo pacman -S cargo
        _echo_run makepkg -si
    fi
    _echo_run paru --noconfirm -Syu

    _info "Installing basic packages..."
    _install_packages "basic packages" "${basic_packages[@]}"

    _setup_btrfs_snapper

    _info "Checking if there's an existing firewall service running..."
    _check_firewall_service "ufw" "ufw"
    _check_firewall_service "nftables" "nft"
    _check_firewall_service "firewalld" "firewalld-cmd"
    if $SETUP_UFW; then
        _info "No existing firewall service running."
        _info "Installing ufw and setting up firewall..."
        _install_pkg "ufw" "--skipreview --noconfirm"
        _ensure_systemd_enabled_now ufw
    fi

    _info "Adding workspace and dotfiles..."
    [ -d "$HOME/Workspace" ] || {
        _info "Creating workspace directory as ~/Workspace..."
        _echo_run mkdir "$HOME/Workspace"
    }
    [ -d "$HOME/Workspace/dotfiles" ] || {
        _info "Cloning dotfiles repository to workspace..."
        _echo_run git clone https://github.com/Aapok0/dotfiles.git "$HOME/Workspace/dotfiles"
        _set_ssh_remote "$HOME/Workspace/dotfiles"
    }

    _info "Moving to dotfiles directory..."
    _echo_run cd "$HOME/Workspace/dotfiles"

    _info "Running full dotfiles setup via justfile (installs packages, stows configs, sets up shell, installs font)..."
    _echo_run just install

    _info "Installing additional AUR packages..."
    _install_packages "basic packages (AUR)" "${basic_packages_aur[@]}"

    _info "Setting up git user configuration..."
    _setup_git_config

    _info "Installing KDE and additional apps..."
    _install_packages "KDE plasma" "${kde_packages[@]}" "${kde_packages_aur[@]}"
    _install_packages "apps" "${apps[@]}" "${apps_aur[@]}"
    _install_packages "gaming packages" "${gaming_packages[@]}" "${gaming_packages_aur[@]}"

    _info "Doing initial setup for nordvpn..."
    if [ -f "/etc/resolv.conf.bak" ]; then
        _info "Systemd-resolved already setup"
    else
        _pkg_is_installed "openresolv" && _echo_run paru -R openresolv
        _echo_run sudo systemctl enable --now systemd-resolved.service
        _echo_run sudo mv /etc/resolv.conf /etc/resolv.conf.bak
        _echo_run sudo ln -s /run/systemd/resolve/stub-resolv.conf /etc/resolv.conf
    fi
    _ensure_group nordvpn
    _ensure_user_in_group "$USERNAME" nordvpn
    _ensure_systemd_enabled_now nordvpnd.service

    _setup_tailscale

    _setup_docker "$USERNAME" "${docker_packages[@]}"

    if command -v steamtinkerlaunch &>/dev/null; then
        _info "Setting Steam Tinker Launch as a Steam compatibility tool..."
        _echo_run steamtinkerlaunch compat add
    else
        _warn "steamtinkerlaunch not installed; skipping compat add"
    fi

    _install_ghostty_desktop_override

    _setup_finalize
}

main "$@"
