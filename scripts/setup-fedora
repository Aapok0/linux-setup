#!/usr/bin/env bash

set -o pipefail

source vars/fedora-vars
USERNAME=$1
SETUP_UFW=true
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
FEDORA_VERSION="$(rpm -E %fedora 2>/dev/null || echo "")"

exec 1> >(tee -a "$LOGFILE") 2>&1

_log() {
    local level="$1" msg="$2"
    printf "[%s] %s: %s\n" "$(date '+%Y-%m-%d %H:%M:%S')" "$level" "$msg"
}

_info() {
    _log "INFO" "$*"
    sleep 2
}

_info_long() {
    _log "INFO" "$*"
    sleep 3
}

_error() {
    _log "ERROR" "$*"
    sleep 3
}

_warn() {
    _log "WARN" "$*"
}

_echo_run() {
    _log "RUN" "$*"
    "$@" || { _error "Command failed: $*"; return 1; }
}

_dnf() {
    sudo dnf "$@"
}

_to_ssh_url() {
    local url=$1
    echo "$url" | sed 's|https://github\.com/|git@github.com:|'
}

_set_ssh_remote() {
    local repo_path=$1
    cd "$repo_path" || return 1
    local https_url=$(git config --get remote.origin.url)
    local ssh_url=$(_to_ssh_url "$https_url")
    if [ "$https_url" != "$ssh_url" ]; then
        _echo_run git remote set-url origin "$ssh_url"
    fi
    cd - > /dev/null || return 1
}

_check_firewall_service() {
    command -v "$2" &> /dev/null && systemctl is-active --quiet "$1" && {
        SETUP_UFW=false
        _log "INFO" "Service $1 already installed/enabled. Check rules manually."; sleep 6
    }
}

_setup_git_config() {
    local config_dir="$HOME/.config/git"
    local config_file="$config_dir/config.local"

    [ -d "$config_dir" ] || _echo_run mkdir -p "$config_dir"

    if [ -f "$config_file" ]; then
        _info "Git config already exists at $config_file"
        return 0
    fi

    _info "Enter your Git user name or real name (or press Enter to skip):"
    read -p "  → " git_name

    if [ -z "$git_name" ]; then
        _warn "Skipped git config setup"
        return 0
    fi

    _info "Enter your Git email:"
    read -p "  → " git_email

    _echo_run mkdir -p "$config_dir"
    cat > "$config_file" << EOF
[user]
    name = $git_name
    email = $git_email
EOF
    _info "Git user config created at $config_file"
}

_pkg_is_installed() {
    rpm -q "$1" &> /dev/null
}

_install_pkg() {
    _pkg_is_installed "$1" && {
        _info "Package $1 already installed"
        return 0
    }
    _info "Installing $1"
    _echo_run _dnf install -y "$1"
}

_install_packages() {
    local category="$1"
    shift
    local packages=("$@")
    [ -n "$category" ] && [ "$category" != "." ] && _info_long "Installing $category..."
    for pkg in "${packages[@]}"; do
        [ -z "$pkg" ] && continue
        [[ "$pkg" == \#* ]] && continue
        _pkg_is_installed "$pkg" && {
            _info "Package $pkg already installed"
            continue
        }
        echo -e "\n[SETUP_INFO] : Installing $pkg\n"
        sleep 2
        _echo_run _dnf install -y "$pkg"
    done
}

_install_flatpak_apps() {
    local category="$1"
    shift
    local apps=("$@")
    [ ${#apps[@]} -eq 0 ] && return 0

    command -v flatpak &> /dev/null || {
        _warn "flatpak not installed; skipping $category"
        return 0
    }

    _info_long "Installing $category..."
    _echo_run flatpak remote-add --if-not-exists flathub https://flathub.org/repo/flathub.flatpakrepo
    for app in "${apps[@]}"; do
        [ -z "$app" ] && continue
        [[ "$app" == \#* ]] && continue
        flatpak list --app | grep -q "$app" && {
            _info "Flatpak $app already installed"
            continue
        }
        echo -e "\n[SETUP_INFO] : Installing flatpak $app\n"
        sleep 2
        _echo_run flatpak install -y flathub "$app"
    done
}

_enable_rpmfusion() {
    [ -n "$FEDORA_VERSION" ] || {
        _warn "Could not detect Fedora version; skipping RPM Fusion setup"
        return 0
    }

    if rpm -q rpmfusion-free-release &> /dev/null && rpm -q rpmfusion-nonfree-release &> /dev/null; then
        _info "RPM Fusion already enabled"
        return 0
    fi

    _info_long "Enabling RPM Fusion free and nonfree repositories..."
    _echo_run _dnf install -y \
        "https://download1.rpmfusion.org/free/fedora/rpmfusion-free-release-${FEDORA_VERSION}.noarch.rpm" \
        "https://download1.rpmfusion.org/nonfree/fedora/rpmfusion-nonfree-release-${FEDORA_VERSION}.noarch.rpm"
}

_setup_nordvpn() {
    if command -v nordvpn &> /dev/null; then
        _info "NordVPN already installed"
        return 0
    fi

    _info_long "Setting up NordVPN..."
    _echo_run sudo rpm --import https://repo.nordvpn.com/gpg/nordvpn_public.asc
    _echo_run sudo tee /etc/yum.repos.d/nordvpn.repo > /dev/null << 'EOF'
[nordvpn]
name=NordVPN
baseurl=https://repo.nordvpn.com/yum/nordvpn/centos/$basearch/
gpgkey=https://repo.nordvpn.com/gpg/nordvpn_public.asc
gpgcheck=1
enabled=1
EOF
    _install_pkg "nordvpn"
    _info "Creating nordvpn group and adding user"
    _echo_run sudo groupadd -r nordvpn 2>/dev/null || true
    _echo_run sudo usermod -aG nordvpn "$USERNAME"
    _info "Enabling and starting nordvpn service..."
    _echo_run sudo systemctl enable nordvpnd.service
    _echo_run sudo systemctl start nordvpnd.service
    _info "NordVPN installed and configured"
    _info "Login with: nordvpn login --token \"<token_from_account_here>\""
}

_setup_systemd_resolved() {
    if [ -f "/etc/resolv.conf.bak" ]; then
        _info "systemd-resolved already setup"
        return 0
    fi

    if [ -L /etc/resolv.conf ] && readlink /etc/resolv.conf | grep -q systemd; then
        _info "systemd-resolved already in use"
        _echo_run sudo systemctl enable --now systemd-resolved.service
        return 0
    fi

    _echo_run sudo systemctl enable --now systemd-resolved.service
    _echo_run sudo mv /etc/resolv.conf /etc/resolv.conf.bak
    _echo_run sudo ln -s /run/systemd/resolve/stub-resolv.conf /etc/resolv.conf
}

main() {
    _info_long "Setting up environment for a Fedora-based distribution."

    _info "Converting linux-setup repository to SSH..."
    if [ -d "$SCRIPT_DIR/.git" ]; then
        _set_ssh_remote "$SCRIPT_DIR"
    fi

    _info_long "Updating package lists and upgrading system..."
    _echo_run _dnf upgrade --refresh -y

    _info_long "Installing dnf tools..."
    _install_packages "dnf tools" "${dnf_tools[@]}"

    _enable_rpmfusion

    _info_long "Installing dnf packages..."
    _install_packages "dnf packages" "${dnf_packages[@]}"

    _info_long "Checking if there's an existing firewall service running..."
    _check_firewall_service "ufw" "ufw"
    _check_firewall_service "nftables" "nft"
    _check_firewall_service "firewalld" "firewall-cmd"
    if $SETUP_UFW; then
        _info "No existing firewall service running."
        _info_long "Installing ufw and setting up firewall..."
        _install_pkg "ufw"
        _info "Enabling firewall tool ufw..."
        _echo_run sudo systemctl enable ufw
        _info "Starting firewall tool ufw..."
        _echo_run sudo systemctl start ufw
    fi

    _info_long "Adding workspace and dotfiles..."
    [ -d "$HOME/Workspace" ] || {
        _info "Creating workspace directory as ~/Workspace..."
        _echo_run mkdir "$HOME/Workspace"
    }
    [ -d "$HOME/Workspace/dotfiles" ] || {
        _info "Cloning dotfiles repository to workspace..."
        _echo_run git clone https://github.com/Aapok0/dotfiles.git "$HOME/Workspace/dotfiles"
        _set_ssh_remote "$HOME/Workspace/dotfiles"
    }

    _info_long "Moving to dotfiles directory..."
    _echo_run cd "$HOME/Workspace/dotfiles"

    _info_long "Running full dotfiles setup via justfile (installs packages, stows configs, sets up shell, installs font)..."
    _echo_run just install

    _info "Setting up git user configuration..."
    _setup_git_config

    _info_long "Installing dnf KDE packages..."
    _install_packages "dnf kde" "${dnf_kde[@]}"
    _info_long "Installing dnf apps..."
    _install_packages "dnf apps" "${dnf_apps[@]}"
    _info_long "Installing dnf gaming packages..."
    _install_packages "dnf gaming" "${dnf_gaming[@]}"
    _info_long "Installing RPM Fusion free packages..."
    _install_packages "rpmfusion free" "${rpmfusion_free_packages[@]}"
    _info_long "Installing RPM Fusion nonfree packages..."
    _install_packages "rpmfusion nonfree" "${rpmfusion_nonfree_packages[@]}"
    _install_flatpak_apps "flatpak apps" "${flatpak_apps[@]}"

    if command -v steamtinkerlaunch &> /dev/null; then
        _info_long "Setting Steam Tinker Launch as a Steam compatibility tool..."
        _echo_run steamtinkerlaunch compat add
    else
        _warn "steamtinkerlaunch not installed; skip compat add (enable in flatpak_apps or install manually)"
    fi

    _info_long "Installing pip/pipx and extra Python CLI tools..."
    _install_pkg "python3-pip"
    _install_pkg "pipx"
    for tool in "${pip_packages[@]}"; do
        command -v "$tool" &> /dev/null && {
            _info "$tool already available"
            continue
        }
        _echo_run pipx install "$tool"
    done

    _info_long "Installing pyenv for Python version management..."
    if ! command -v pyenv &> /dev/null; then
        _info "Cloning pyenv..."
        _echo_run git clone https://github.com/pyenv/pyenv.git "$HOME/.pyenv"
        _info "Building pyenv..."
        _echo_run cd "$HOME/.pyenv" && src/configure && make -C src
        _info "Pyenv installed to ~/.pyenv"
        _info "Add the following to your shell startup file (~/.zshrc or ~/.bashrc):"
        echo '  export PYENV_ROOT="$HOME/.pyenv"'
        echo '  export PATH="$PYENV_ROOT/bin:$PATH"'
        echo '  eval "$(pyenv init --path)"'
        echo '  eval "$(pyenv init -)"'
    else
        _info "Pyenv already installed"
    fi

    _info_long "Installing tfswitch for Terraform version management..."
    if ! command -v tfswitch &> /dev/null; then
        _info "Downloading tfswitch..."
        _echo_run mkdir -p "$HOME/.local/bin"
        _echo_run curl -L https://raw.githubusercontent.com/warrensbox/terraform-switcher/master/install.sh | bash -s -- -b "$HOME/.local/bin"
        _info "tfswitch installed to ~/.local/bin/tfswitch"
        _info "Make sure ~/.local/bin is in your PATH"
    else
        _info "tfswitch already installed"
    fi

    _info_long "Installing nvm for Node version management..."
    if ! command -v nvm &> /dev/null; then
        _info "Downloading and installing nvm..."
        _echo_run curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.1/install.sh | bash
        _info "nvm installed"
        _info "Add the following to your shell startup file (~/.zshrc or ~/.bashrc):"
        echo '  export NVM_DIR="$HOME/.nvm"'
        echo '  [ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"'
        echo '  [ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"'
    else
        _info "nvm already installed"
    fi

    _info_long "Doing initial setup for systemd-resolved (for DNS)..."
    _setup_systemd_resolved

    _setup_nordvpn

    _log "INFO" "Setup completed. Log saved to: $LOGFILE"
}

main "$@" || return 1
