#!/usr/bin/env bash

# Exit codes:
#   0 - success
#   1 - error
#   2 - user cancelled

set -uo pipefail

# Repo root (parent of scripts/) — absolute path, independent of cwd
REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
timestamp=$(date +"%Y-%m-%d_%H:%M:%S")
LOGFILE="${REPO_ROOT}/logs/${timestamp}_install-arch.log"

mkdir -p "${REPO_ROOT}/logs"
exec 1> >(tee -a "$LOGFILE") 2>&1

# Configuration variables
ROOT_DEVICE=""
ROOT_SIZE=""
ROOT_SIZE_UNIT=""
HOME_DEVICE=""
HOME_SIZE=""
HOME_SIZE_UNIT=""
SWAP_TYPE=""
SWAP_SIZE=""
HIBERNATION_ENABLED=false
ENCRYPTION_ENABLED=false

# Resolved partition paths (set after partitioning)
EFI_PARTITION=""
BOOT_PARTITION=""
ROOT_PARTITION=""
HOME_PARTITION=""
SWAP_PARTITION=""

# LVM names (match arch-install.md)
VG_ROOT="arch"
VG_HOME="arch_home"
LV_ROOT="root"
LV_HOME="home"
LV_SWAP="swap"

# Resolved logical volume paths (set after LVM setup)
ROOT_LV=""
HOME_LV=""
SWAP_LV=""

# Install target (set before mounting)
INSTALL_USERNAME=""
MNT="/mnt"
BTRFS_MOUNT_OPTS="noatime,ssd,compress=zstd,space_cache=v2,discard=async,commit=120"

# Mirror configuration (match arch-install.md)
REFLECTOR_COUNTRY="Finland"
REFLECTOR_AGE=12
REFLECTOR_COUNTRIES="Finland,Sweden"

# Localization defaults (match arch-install.md)
INSTALL_HOSTNAME=""
TIMEZONE="Europe/Helsinki"
KEYMAP="fi"

# Boot partition sizes (in GB)
BOOT_EFI_SIZE=1
BOOT_SIZE=4

# Device list (populated by _list_available_devices)
declare -a AVAILABLE_DEVICES

# ============================================================================
# Logging and output functions
# ============================================================================

_log() {
    local level="$1"
    shift
    printf "[%s] %s: %s\n" "$(date '+%Y-%m-%d %H:%M:%S')" "$level" "$*" >&2
}

_out() {
    _log "OUT" "$@"
}

_section() {
    _out "=========================================="
    _out "$1"
    _out "=========================================="
}

_info() {
    _log "INFO" "$@"
}

_error() {
    _log "ERROR" "$@"
}

_warn() {
    _log "WARN" "$@"
}

_log_cmd_output() {
    local output rc=0

    _log "RUN" "$*"
    output=$("$@" 2>&1) || rc=$?

    if [ -n "$output" ]; then
        while IFS= read -r line; do
            _log "OUT" "$line"
        done <<< "$output"
    fi

    return "$rc"
}

_echo_run() {
    _log "RUN" "$*"
    "$@" || {
        _error "Command failed (exit $?): $*"
        return 1
    }
}

_log_interactive() {
    _log "RUN" "$* (interactive)"
}

_propagate_rc() {
    local rc=$1
    local err_msg=${2:-}

    case $rc in
        0) return 0 ;;
        2) return 2 ;;
        *)
            if [ -n "$err_msg" ]; then
                _error "$err_msg"
            fi
            return 1
            ;;
    esac
}

_run_phase() {
    local name=$1 rc
    shift

    _section "Phase: ${name}"
    _info "Starting phase: ${name}"
    "$@"
    rc=$?
    if [ $rc -eq 0 ]; then
        _info "Phase completed: ${name}"
    fi
    _propagate_rc $rc "${name} failed"
}

_exit_on_rc() {
    local rc=$1

    case $rc in
        0) return 0 ;;
        2)
            _info "Installation cancelled by user. Exiting."
            exit 0
            ;;
        *)
            exit 1
            ;;
    esac
}

# ============================================================================
# Device discovery and display functions
# ============================================================================

_get_device_size() {
    local device=$1
    lsblk -bdn -o SIZE "$device" 2>/dev/null | head -1
}

_human_readable_size() {
    local bytes=$1
    numfmt --to=iec-i --suffix=B "$bytes" 2>/dev/null || {
        # Fallback if numfmt is not available
        echo "$(( bytes / 1024 / 1024 / 1024 ))GB"
    }
}

_list_available_devices() {
    _info "Scanning available block devices..."

    local -a devices

    # Get all block devices (excluding partitions and loops)
    while IFS= read -r line; do
        devices+=("$line")
    done < <(lsblk -dln -o NAME,SIZE,MODEL 2>/dev/null | grep -v loop)

    if [ ${#devices[@]} -eq 0 ]; then
        _error "No block devices found. Aborting."
        return 1
    fi

    # Store globally for use in selection function
    AVAILABLE_DEVICES=("${devices[@]}")

    _section "Available Block Devices"

    local idx=0
    while [ $idx -lt ${#devices[@]} ]; do
        _out "[$idx] ${devices[$idx]}"
        ((idx++))
    done

    _out ""
    return 0
}

_prompt_device_selection() {
    local prompt_msg=$1
    local device_var=$2
    local selected_device
    local device_name

    while true; do
        read -p "$prompt_msg" selected_device

        # Check, if input is an index number
        if [[ $selected_device =~ ^[0-9]+$ ]]; then
            if [ "$selected_device" -lt ${#AVAILABLE_DEVICES[@]} ]; then
                # Extract device name from the list entry (format: "NAME SIZE MODEL")
                device_name=$(echo "${AVAILABLE_DEVICES[$selected_device]}" | awk '{print $1}')
                # Change to /dev/xxx format
                selected_device="/dev/$device_name"
                eval "$device_var=$selected_device"
                _info "Selected device: $selected_device (Size: $(_human_readable_size $(_get_device_size "$selected_device")))"
                return 0
            else
                _error "Invalid index: $selected_device. Please enter a valid index."
                continue
            fi
        fi

        # Validate device exists (direct name or path input)
        #   - Device can be selected with both index and name/path
        if [ -b "/dev/$selected_device" ] || [ -b "$selected_device" ]; then
            # Normalize to /dev/xxx format
            if [[ ! "$selected_device" =~ ^/dev/ ]]; then
                selected_device="/dev/$selected_device"
            fi
            eval "$device_var=$selected_device"
            _info "Selected device: $selected_device (Size: $(_human_readable_size $(_get_device_size "$selected_device")))"
            return 0
        else
            _error "Invalid device or index: $selected_device. Please try again."
        fi
    done
}

# ============================================================================
# Partition sizing functions
# ============================================================================

_calculate_available_space() {
    local device=$1
    local partition_name=$2
    local device_size_bytes=$(_get_device_size "$device")
    local device_size_gb=$(( device_size_bytes / 1024 / 1024 / 1024 ))
    local reserved_space=0

    # Reserve boot partitions, if on same device as root
    if [ "$partition_name" = "ROOT" ]; then
        reserved_space=$(( BOOT_EFI_SIZE + BOOT_SIZE ))
        # Only reserve swap, if it's a partition (not LVM)
        if [ "$SWAP_TYPE" = "partition" ] && [ -n "$SWAP_SIZE" ]; then
            reserved_space=$(( reserved_space + SWAP_SIZE ))
        fi
    fi

    # Reserve boot partitions, swap, and root, if home is on same device as root
    if [ "$partition_name" = "HOME" ] && [ "$HOME_DEVICE" = "$ROOT_DEVICE" ]; then
        reserved_space=$(( reserved_space + BOOT_EFI_SIZE + BOOT_SIZE ))
        # Only reserve swap, if it's a partition (not LVM)
        if [ "$SWAP_TYPE" = "partition" ] && [ -n "$SWAP_SIZE" ]; then
            reserved_space=$(( reserved_space + SWAP_SIZE ))
        fi
        # Also reserve root partition size, if specified
        if [ -n "$ROOT_SIZE" ]; then
            reserved_space=$(( reserved_space + ROOT_SIZE ))
        fi
    fi

    local available_gb=$(( device_size_gb - reserved_space ))
    if [ $available_gb -lt 0 ]; then
        available_gb=0
    fi

    echo $available_gb
}

_prompt_partition_size() {
    local partition_name=$1
    local device=$2
    local device_size_bytes=$(_get_device_size "$device")
    local device_size_human=$(_human_readable_size $device_size_bytes)
    local available_gb=$(_calculate_available_space "$device" "$partition_name")
    local size_value
    local size_unit

    while true; do
        _out ""
        _out "Configuring size for $partition_name on $device"
        _out "  Total device size: ~$device_size_human"
        _out "  Available space:   ~${available_gb}GB"

        if [ "$partition_name" = "ROOT" ]; then
            if [ "$SWAP_TYPE" = "partition" ]; then
                _out "  Reserved: Boot EFI (${BOOT_EFI_SIZE}GB) + Boot (${BOOT_SIZE}GB) + Swap (${SWAP_SIZE}GB)"
            else
                _out "  Reserved: Boot EFI (${BOOT_EFI_SIZE}GB) + Boot (${BOOT_SIZE}GB)"
            fi
        fi

        if [ "$partition_name" = "HOME" ] && [ "$HOME_DEVICE" = "$ROOT_DEVICE" ]; then
            if [ "$SWAP_TYPE" = "partition" ]; then
                _out "  Reserved: Boot EFI (${BOOT_EFI_SIZE}GB) + Boot (${BOOT_SIZE}GB) + Swap (${SWAP_SIZE}GB) + ROOT (${ROOT_SIZE}${ROOT_SIZE_UNIT})"
            else
                _out "  Reserved: Boot EFI (${BOOT_EFI_SIZE}GB) + Boot (${BOOT_SIZE}GB) + ROOT (${ROOT_SIZE}${ROOT_SIZE_UNIT})"
            fi
        fi

        read -p "Enter size (e.g., '100G' for 100GB or 'all' to use all available space): " size_input

        if [ "$size_input" = "all" ]; then
            eval "${partition_name}_SIZE=all"
            eval "${partition_name}_SIZE_UNIT=all"
            _info "$partition_name will use all available space"
            return 0
        fi

        # Validate size format (must end with G, T, M, etc.)
        if [[ $size_input =~ ^[0-9]+[GMT]$ ]]; then
            eval "${partition_name}_SIZE=${size_input%?}"
            eval "${partition_name}_SIZE_UNIT=${size_input: -1}"
            _info "$partition_name size set to: $size_input"
            return 0
        else
            _error "Invalid format. Please use format like '100G', '1T', '512M', or 'all'"
        fi
    done
}

# ============================================================================
# Swap configuration functions
# ============================================================================

_get_total_ram() {
    local ram_kb
    ram_kb=$(grep MemTotal /proc/meminfo | awk '{print $2}')
    # Convert KB to GB - round to nearest GB
    echo $(( (ram_kb + 524287) / 1048576 ))
}

_prompt_swap_type() {
    local swap_type

    _section "Swap Configuration"
    _out ""

    while true; do
        _out "Select swap type:"
        _out "[1] Swap as partition"
        _out "[2] Swap as LVM logical volume"
        read -p "Enter choice [1 or 2]: " swap_type

        case $swap_type in
            1)
                SWAP_TYPE="partition"
                _info "Swap will be created as a partition"
                return 0
                ;;
            2)
                SWAP_TYPE="lvm"
                _info "Swap will be created as an LVM logical volume"
                return 0
                ;;
            *)
                _error "Invalid choice. Please enter 1 or 2."
                ;;
        esac
    done
}

_prompt_hibernation() {
    local response

    _out ""
    read -p "Do you need hibernation support? (y/n): " response

    if [[ $response =~ ^[Yy]$ ]]; then
        HIBERNATION_ENABLED=true
        _info "Hibernation support enabled"
    else
        HIBERNATION_ENABLED=false
        _info "Hibernation support disabled"
    fi
}

_calculate_sqrt() {
    local num=$1
    local sqrt=0
    local bit=1

    # Find the highest bit
    while [ $((bit * bit)) -le $num ]; do
        bit=$((bit * 2))
    done
    bit=$((bit / 2))

    # Binary search for square root
    while [ $bit -gt 0 ]; do
        if [ $(((sqrt + bit) * (sqrt + bit))) -le $num ]; then
            sqrt=$((sqrt + bit))
        fi
        bit=$((bit / 2))
    done

    echo $sqrt
}

_calculate_swap_size() {
    local ram_gb=$(_get_total_ram)
    local swap_gb
    local sqrt_ram

    sqrt_ram=$(_calculate_sqrt $ram_gb)

    if [ "$HIBERNATION_ENABLED" = true ]; then
        # For hibernation: RAM + sqrt(RAM)
        swap_gb=$(( ram_gb + sqrt_ram ))
        _info "Swap size for hibernation: ${swap_gb}GB (RAM: ${ram_gb}GB + sqrt(RAM): ${sqrt_ram}GB)"
    else
        # For non-hibernation: sqrt(RAM), minimum 2GB
        swap_gb=$sqrt_ram
        if [ $swap_gb -lt 2 ]; then
            swap_gb=2
        fi
        _info "Swap size without hibernation: sqrt(RAM): ${swap_gb}GB"
    fi

    SWAP_SIZE=$swap_gb
}

# ============================================================================
# Validation and summary functions
# ============================================================================

_validate_devices() {
    if [ -z "$ROOT_DEVICE" ]; then
        _error "Root device not selected"
        return 1
    fi

    if [ -z "$HOME_DEVICE" ]; then
        _error "Home device not selected"
        return 1
    fi

    if [ "$ROOT_DEVICE" = "$HOME_DEVICE" ]; then
        _info "Root and home will be on the same device"
        if [ "$ROOT_SIZE_UNIT" = "all" ]; then
            _error "Root cannot use all space when home is on the same device. Specify a root size."
            return 1
        fi
    else
        _info "Root and home will be on separate devices"
    fi

    return 0
}

_print_configuration_summary() {
    local root_display
    local home_display

    # Display root and home partition size even, when all is selected 
    if [ "$ROOT_SIZE_UNIT" = "all" ]; then
        local available_root=$(_calculate_available_space "$ROOT_DEVICE" "ROOT")
        root_display="${available_root}GB (all available)"
    else
        root_display="${ROOT_SIZE}${ROOT_SIZE_UNIT}"
    fi

    if [ "$HOME_SIZE_UNIT" = "all" ]; then
        local available_home=$(_calculate_available_space "$HOME_DEVICE" "HOME")
        home_display="${available_home}GB (all available)"
    else
        home_display="${HOME_SIZE}${HOME_SIZE_UNIT}"
    fi

    _section "Installation Configuration Summary"
    _out ""
    _out "Root Device:              $ROOT_DEVICE"
    _out "Root Partition Size:      $root_display"
    _out ""
    _out "Home Device:              $HOME_DEVICE"
    _out "Home Partition Size:      $home_display"
    _out ""
    _out "Swap Type:                $SWAP_TYPE"
    _out "Swap Size:                ${SWAP_SIZE}GB"
    _out "Hibernation Support:      $([ "$HIBERNATION_ENABLED" = true ] && echo "Yes" || echo "No")"
    _out ""
}

_confirm_configuration() {
    local response

    while true; do
        read -r -p "Do you want to proceed with this configuration? (yes/no): " response

        case $response in
            yes)
                _out "Configuration confirmed: yes"
                _info "Configuration confirmed"
                return 0
                ;;
            no)
                _out "Configuration confirmed: no"
                _info "Configuration cancelled by user"
                return 2
                ;;
            *)
                _warn "Please enter 'yes' or 'no'"
                ;;
        esac
    done
}

_prompt_yes_no() {
    local prompt_msg=$1
    local response

    while true; do
        read -r -p "$prompt_msg" response

        case $response in
            [Yy]|[Yy][Ee][Ss])
                _out "${prompt_msg} yes"
                return 0
                ;;
            [Nn]|[Nn][Oo])
                _out "${prompt_msg} no"
                return 1
                ;;
            *)
                _warn "Please enter y or n"
                ;;
        esac
    done
}

# ============================================================================
# Partitioning functions
# ============================================================================

_prompt_format_confirmation() {
    local device=$1
    local response

    _out ""
    _warn "WARNING: This will DESTROY all data on $device"
    _warn "All existing partitions and data will be permanently lost."
    _out ""

    while true; do
        read -p "Do you want to format $device and create new partitions? (yes/no): " response

        case $response in
            yes)
                _warn "Formatting $device - Point of no return!"
                return 0
                ;;
            no)
                _info "Format cancelled by user"
                return 2
                ;;
            *)
                _warn "Please enter 'yes' or 'no'"
                ;;
        esac
    done
}

_setup_disk_partitions() {
    local device=$1
    local root_size=$2
    local root_unit=$3
    local swap_size=$4
    local swap_on_this_device=$5
    local is_root_device=$6

    # Prompt for confirmation before destructive operation
    _prompt_format_confirmation "$device"
    _propagate_rc $? || return $?

    _info "Initializing partition table on $device..."

    # Create a new GPT partition table
    _echo_run parted -s "$device" mklabel gpt || return 1

    local start="0%"
    local end

    # Create EFI boot partition (1GB)
    if [ "$is_root_device" = true ]; then
        end="1GB"
        _info "Creating EFI boot partition (1GB)..."
        _echo_run parted -s -a optimal "$device" mkpart boot_efi fat32 "$start" "$end" || return 1

        start="1GB"
        end="5GB"
        _info "Creating boot partition (4GB)..."
        _echo_run parted -s -a optimal "$device" mkpart boot ext4 "$start" "$end" || return 1

        start="5GB"
    fi

    # Create swap partition (if on this device and as partition)
    if [ "$swap_on_this_device" = true ] && [ "$SWAP_TYPE" = "partition" ]; then
        end="$((5 + swap_size))GB"
        _info "Creating swap partition (${swap_size}GB)..."
        _echo_run parted -s -a optimal "$device" mkpart swap linux-swap "$start" "$end" || return 1

        start="$((5 + swap_size))GB"
    fi

    # Create root or home partition
    if [ "$is_root_device" = true ]; then
        if [ "$root_unit" = "all" ]; then
            end="100%"
            _info "Creating root partition (all remaining space)..."
        else
            end="$((5 + (swap_on_this_device && [ "$SWAP_TYPE" = "partition" ] ? swap_size : 0) + root_size))${root_unit}"
            _info "Creating root partition (${root_size}${root_unit})..."
        fi
        _echo_run parted -s -a optimal "$device" mkpart root linux "$start" "$end" || return 1

        if [ "$HOME_DEVICE" = "$device" ]; then
            start="$end"
            if [ "$HOME_SIZE_UNIT" = "all" ]; then
                end="100%"
                _info "Creating home partition (all remaining space)..."
            else
                end="+${HOME_SIZE}${HOME_SIZE_UNIT}"
                _info "Creating home partition (${HOME_SIZE}${HOME_SIZE_UNIT})..."
            fi
            _echo_run parted -s -a optimal "$device" mkpart home linux "$start" "$end" || return 1
        fi
    else
        # Home device
        if [ "$root_unit" = "all" ]; then
            end="100%"
            _info "Creating home partition (all remaining space)..."
        else
            end="${root_size}${root_unit}"
            _info "Creating home partition (${root_size}${root_unit})..."
        fi
        _echo_run parted -s -a optimal "$device" mkpart home linux "$start" "$end" || return 1
    fi

    _info "Refreshing partition table on $device..."
    _echo_run partprobe "$device" || return 1
    if command -v udevadm &>/dev/null; then
        udevadm settle
    fi

    _info "Partition table on $device created successfully"
    return 0
}

_resolve_partition_by_label() {
    local device=$1
    local label=$2
    local part

    part=$(lsblk -ln -o NAME,PARTLABEL "$device" 2>/dev/null \
        | awk -v label="$label" '$2 == label {print "/dev/" $1; exit}')

    if [ -z "$part" ] || [ ! -b "$part" ]; then
        _error "Could not resolve partition '$label' on $device"
        return 1
    fi

    echo "$part"
}

_resolve_partition_paths() {
    _info "Resolving partition paths..."

    EFI_PARTITION=$(_resolve_partition_by_label "$ROOT_DEVICE" boot_efi) || return 1
    BOOT_PARTITION=$(_resolve_partition_by_label "$ROOT_DEVICE" boot) || return 1
    ROOT_PARTITION=$(_resolve_partition_by_label "$ROOT_DEVICE" root) || return 1
    HOME_PARTITION=$(_resolve_partition_by_label "$HOME_DEVICE" home) || return 1

    if [ "$SWAP_TYPE" = "partition" ]; then
        SWAP_PARTITION=$(_resolve_partition_by_label "$ROOT_DEVICE" swap) || return 1
    else
        SWAP_PARTITION=""
    fi

    _info "EFI:  $EFI_PARTITION"
    _info "Boot: $BOOT_PARTITION"
    _info "Root: $ROOT_PARTITION"
    _info "Home: $HOME_PARTITION"
    if [ -n "$SWAP_PARTITION" ]; then
        _info "Swap: $SWAP_PARTITION"
    fi

    return 0
}

_get_pv_device() {
    local target=$1

    if [ "$ENCRYPTION_ENABLED" = true ]; then
        case $target in
            root) echo "/dev/mapper/luks_root" ;;
            home) echo "/dev/mapper/luks_home" ;;
            *)
                _error "Unknown PV target: $target"
                return 1
                ;;
        esac
    else
        case $target in
            root) echo "$ROOT_PARTITION" ;;
            home) echo "$HOME_PARTITION" ;;
            *)
                _error "Unknown PV target: $target"
                return 1
                ;;
        esac
    fi
}

_get_swap_device() {
    if [ "$SWAP_TYPE" = "lvm" ]; then
        echo "$SWAP_LV"
    else
        echo "$SWAP_PARTITION"
    fi
}

_print_partition_summary() {
    local device=$1

    _info "Current partition table for $device:"
    _log_cmd_output parted -s "$device" print
}

# ============================================================================
# Disk setup phase
# ============================================================================

_setup_disk_configuration() {
    _info "Starting Arch Linux disk setup configuration"
    _list_available_devices
    _propagate_rc $? || return $?

    # Select root device
    _prompt_device_selection "Enter root device index number or name (e.g., 1, 2 or sda, nvme0n1): " ROOT_DEVICE
    _propagate_rc $? || return $?

    # Select home device
    _prompt_device_selection "Enter home device index number or name (e.g., 1, 2 or sda, nvme0n1, or same as root): " HOME_DEVICE
    _propagate_rc $? || return $?

    # Configure swap BEFORE partition sizes (so available space can be calculated)
    _prompt_swap_type
    _propagate_rc $? || return $?
    _prompt_hibernation
    _calculate_swap_size

    # Configure root partition size (accounting for boot and swap)
    _prompt_partition_size "ROOT" "$ROOT_DEVICE"
    _propagate_rc $? || return $?

    # Configure home partition size (accounting for reserved space)
    _prompt_partition_size "HOME" "$HOME_DEVICE"
    _propagate_rc $? || return $?

    # Validate and display summary
    _validate_devices
    _propagate_rc $? || return $?
    _print_configuration_summary
    _confirm_configuration
    _propagate_rc $? || return $?

    _info "Proceeding with disk partitioning"

    # Partition root device
    _info "Partitioning root device: $ROOT_DEVICE"
    local swap_on_root=false
    if [ "$SWAP_TYPE" = "partition" ]; then
        swap_on_root=true
    fi
    _setup_disk_partitions "$ROOT_DEVICE" "$ROOT_SIZE" "$ROOT_SIZE_UNIT" "$SWAP_SIZE" "$swap_on_root" true
    _propagate_rc $? "Failed to partition root device" || return $?

    # Partition home device if it's different from root
    if [ "$HOME_DEVICE" != "$ROOT_DEVICE" ]; then
        _info "Partitioning home device: $HOME_DEVICE"
        _setup_disk_partitions "$HOME_DEVICE" "$HOME_SIZE" "$HOME_SIZE_UNIT" 0 false false
        _propagate_rc $? "Failed to partition home device" || return $?
    fi

    # Display final partition tables
    _print_partition_summary "$ROOT_DEVICE"

    if [ "$HOME_DEVICE" != "$ROOT_DEVICE" ]; then
        _print_partition_summary "$HOME_DEVICE"
    fi

    _resolve_partition_paths
    _propagate_rc $? "Failed to resolve partition paths" || return $?

    _info "Disk configuration and partitioning completed successfully"

    return 0
}

# ============================================================================
# Encryption functions
# ============================================================================

_load_crypt_modules() {
    _info "Loading encryption kernel modules..."
    _echo_run modprobe dm-crypt || return 1
    _echo_run modprobe dm-mod || return 1
}

_encrypt_and_open_partition() {
    local partition=$1
    local mapper_name=$2

    _out ""
    _warn "WARNING: LUKS formatting will erase all data on $partition"
    _warn "You will be prompted to enter and verify a passphrase."
    _warn "Save this passphrase somewhere safe — you need it to boot."
    _out ""

    if ! _prompt_yes_no "Format $partition with LUKS2 encryption? (y/n): "; then
        _info "Encryption cancelled for $partition"
        return 2
    fi

    _info "Formatting $partition with LUKS2..."
    _log_interactive cryptsetup luksFormat -v -s 512 -h sha512 --type luks2 "$partition"
    cryptsetup luksFormat -v -s 512 -h sha512 --type luks2 "$partition" || {
        _error "luksFormat failed for $partition"
        return 1
    }

    _info "Opening $partition as $mapper_name..."
    _log_interactive cryptsetup open "$partition" "$mapper_name"
    cryptsetup open "$partition" "$mapper_name" || {
        _error "Failed to open $partition as $mapper_name"
        return 1
    }

    _info "Opened $partition as /dev/mapper/$mapper_name"
    return 0
}

_setup_encryption() {
    if ! command -v cryptsetup &>/dev/null; then
        _error "cryptsetup not found. Install it or use the Arch live ISO."
        return 1
    fi

    _load_crypt_modules
    _propagate_rc $? || return $?

    _encrypt_and_open_partition "$ROOT_PARTITION" luks_root
    _propagate_rc $? || return $?
    _encrypt_and_open_partition "$HOME_PARTITION" luks_home
    _propagate_rc $? || return $?

    _info "Encryption completed"
    _info "Root PV: $(_get_pv_device root)"
    _info "Home PV: $(_get_pv_device home)"

    return 0
}

# ============================================================================
# LVM functions
# ============================================================================

_setup_root_volume_group() {
    local pv

    pv=$(_get_pv_device root) || return 1

    _info "Creating physical volume on $pv..."
    _echo_run pvcreate "$pv" || return 1

    _info "Creating volume group $VG_ROOT..."
    _echo_run vgcreate "$VG_ROOT" "$pv" || return 1

    if [ "$SWAP_TYPE" = "lvm" ]; then
        _info "Creating swap logical volume (${SWAP_SIZE}GB)..."
        _echo_run lvcreate -n "$LV_SWAP" -L "${SWAP_SIZE}G" -C y "$VG_ROOT" || return 1
        SWAP_LV="/dev/mapper/${VG_ROOT}-${LV_SWAP}"
        _info "Swap LV: $SWAP_LV"
    fi

    if [ "$SWAP_TYPE" = "lvm" ] || [ "$ROOT_SIZE_UNIT" = "all" ]; then
        _info "Creating root logical volume (all remaining space in $VG_ROOT)..."
        _echo_run lvcreate -n "$LV_ROOT" -l +100%FREE "$VG_ROOT" || return 1
    else
        _info "Creating root logical volume (${ROOT_SIZE}${ROOT_SIZE_UNIT})..."
        _echo_run lvcreate -n "$LV_ROOT" -L "${ROOT_SIZE}${ROOT_SIZE_UNIT}" "$VG_ROOT" || return 1
    fi

    ROOT_LV="/dev/mapper/${VG_ROOT}-${LV_ROOT}"
    _info "Root LV: $ROOT_LV"

    return 0
}

_setup_home_volume_group() {
    local pv

    pv=$(_get_pv_device home) || return 1

    _info "Creating physical volume on $pv..."
    _echo_run pvcreate "$pv" || return 1

    _info "Creating volume group $VG_HOME..."
    _echo_run vgcreate "$VG_HOME" "$pv" || return 1

    if [ "$HOME_SIZE_UNIT" = "all" ]; then
        _info "Creating home logical volume (all remaining space in $VG_HOME)..."
        _echo_run lvcreate -n "$LV_HOME" -l +100%FREE "$VG_HOME" || return 1
    else
        _info "Creating home logical volume (${HOME_SIZE}${HOME_SIZE_UNIT})..."
        _echo_run lvcreate -n "$LV_HOME" -L "${HOME_SIZE}${HOME_SIZE_UNIT}" "$VG_HOME" || return 1
    fi

    HOME_LV="/dev/mapper/${VG_HOME}-${LV_HOME}"
    _info "Home LV: $HOME_LV"

    return 0
}

_activate_volume_groups() {
    _info "Scanning and activating volume groups..."
    _echo_run vgscan || return 1
    _echo_run vgchange -ay || return 1
}

_print_lvm_summary() {
    _section "LVM Summary"
    _log_cmd_output vgs
    _out ""
    _log_cmd_output lvs
    _out "=========================================="
    _out ""
}

_setup_lvm() {
    _info "Setting up LVM volume groups"

    _setup_root_volume_group
    _propagate_rc $? "Failed to set up root volume group" || return $?

    _setup_home_volume_group
    _propagate_rc $? "Failed to set up home volume group" || return $?

    _activate_volume_groups
    _propagate_rc $? || return $?
    _print_lvm_summary

    _info "LVM setup completed"
    return 0
}

# ============================================================================
# Filesystem functions
# ============================================================================

_prompt_install_username() {
    local username

    _section "Installation Username"
    _out "Used for the home Media subvolume mount path."
    _out ""

    while true; do
        read -p "Enter planned username: " username

        if [[ $username =~ ^[a-z_][a-z0-9_-]*$ ]]; then
            INSTALL_USERNAME=$username
            _info "Username set to: $INSTALL_USERNAME"
            return 0
        fi

        _error "Invalid username. Use lowercase letters, numbers, underscore, or hyphen."
    done
}

_prompt_filesystem_confirmation() {
    _out ""
    _warn "WARNING: This will format filesystems on the following devices:"
    _warn "  EFI:  $EFI_PARTITION (vfat)"
    _warn "  Boot: $BOOT_PARTITION (ext4)"
    _warn "  Root: $ROOT_LV (btrfs)"
    _warn "  Home: $HOME_LV (btrfs)"
    if [ -n "$(_get_swap_device)" ]; then
        _warn "  Swap: $(_get_swap_device)"
    fi
    _out ""
    _warn "All existing data on these volumes will be permanently lost."
    _out ""

    if ! _prompt_yes_no "Create filesystems on these devices? (y/n): "; then
        _info "Filesystem creation cancelled by user"
        return 2
    fi

    return 0
}

_format_filesystems() {
    _info "Formatting EFI partition: $EFI_PARTITION"
    _echo_run mkfs.fat -F 32 "$EFI_PARTITION" || return 1

    _info "Formatting boot partition: $BOOT_PARTITION"
    _echo_run mkfs.ext4 "$BOOT_PARTITION" || return 1

    local swap_device
    swap_device=$(_get_swap_device)
    if [ -n "$swap_device" ]; then
        _info "Formatting swap: $swap_device"
        _echo_run mkswap "$swap_device" || return 1
    fi

    _info "Formatting root volume: $ROOT_LV"
    _echo_run mkfs.btrfs -L root "$ROOT_LV" || return 1

    _info "Formatting home volume: $HOME_LV"
    _echo_run mkfs.btrfs -L home "$HOME_LV" || return 1

    return 0
}

_create_btrfs_subvolumes() {
    _info "Creating root btrfs subvolumes on $ROOT_LV..."

    if mountpoint -q "$MNT"; then
        _error "$MNT is already mounted. Unmount it before continuing."
        return 1
    fi

    _echo_run mount "$ROOT_LV" "$MNT" || return 1
    _echo_run btrfs subvolume create "$MNT/@" || return 1
    _echo_run btrfs subvolume create "$MNT/@snapshots" || return 1
    _echo_run btrfs subvolume create "$MNT/@var_log" || return 1
    _echo_run btrfs subvolume create "$MNT/@var_cache" || return 1
    _echo_run umount -R "$MNT" || return 1

    _info "Creating home btrfs subvolumes on $HOME_LV..."

    _echo_run mount --mkdir "$HOME_LV" "${MNT}/home" || return 1
    _echo_run btrfs subvolume create "${MNT}/home/@home" || return 1
    _echo_run btrfs subvolume create "${MNT}/home/@home/@snapshots" || return 1
    _echo_run btrfs subvolume create "${MNT}/home/@home/@media" || return 1
    _echo_run umount -R "$MNT" || return 1

    return 0
}

_mount_installation() {
    local btrfs_opts="$BTRFS_MOUNT_OPTS"
    local swap_device

    _info "Mounting installation target at $MNT..."

    if mountpoint -q "$MNT"; then
        _error "$MNT is already mounted. Unmount it before continuing."
        return 1
    fi

    _echo_run mount -o "$btrfs_opts,subvol=/@" "$ROOT_LV" "$MNT" || return 1
    _echo_run mount --mkdir -o "$btrfs_opts,subvol=/@snapshots" "$ROOT_LV" "${MNT}/.snapshots" || return 1
    _echo_run mount --mkdir -o "$btrfs_opts,subvol=/@var_log" "$ROOT_LV" "${MNT}/var/log" || return 1
    _echo_run mount --mkdir -o "$btrfs_opts,subvol=/@var_cache" "$ROOT_LV" "${MNT}/var/cache" || return 1
    _echo_run mount --mkdir "$BOOT_PARTITION" "${MNT}/boot" || return 1
    _echo_run mount --mkdir "$EFI_PARTITION" "${MNT}/boot/efi" || return 1
    _echo_run mount --mkdir -o "$btrfs_opts,subvol=/@home" "$HOME_LV" "${MNT}/home" || return 1
    _echo_run mount --mkdir -o "$btrfs_opts,subvol=/@home/@snapshots" "$HOME_LV" "${MNT}/home/.snapshots" || return 1
    _echo_run mount --mkdir -o "$btrfs_opts,subvol=/@home/@media" "$HOME_LV" "${MNT}/home/${INSTALL_USERNAME}/Media" || return 1

    swap_device=$(_get_swap_device)
    if [ -n "$swap_device" ]; then
        _info "Enabling swap: $swap_device"
        _echo_run swapon "$swap_device" || return 1
    fi

    return 0
}

_print_mount_summary() {
    _section "Mount Summary"
    _log_cmd_output findmnt -R "$MNT"
    _out "=========================================="
    _out ""
}

_setup_filesystems() {
    _check_filesystem_tools
    _propagate_rc $? || return $?

    _prompt_install_username
    _propagate_rc $? || return $?

    _prompt_filesystem_confirmation
    _propagate_rc $? || return $?

    _info "Creating filesystems"

    _format_filesystems
    _propagate_rc $? "Failed to create filesystems" || return $?

    _create_btrfs_subvolumes
    _propagate_rc $? "Failed to create btrfs subvolumes" || return $?

    _mount_installation
    _propagate_rc $? "Failed to mount installation target" || return $?

    _print_mount_summary

    _info "Filesystem setup completed"
    return 0
}

# ============================================================================
# Bootstrap and chroot boot functions
# ============================================================================

_chroot_run() {
    _log "RUN" "arch-chroot ${MNT} $*"
    arch-chroot "$MNT" "$@"
}

_get_uuid() {
    local device=$1
    blkid -s UUID -o value "$device"
}

_configure_live_mirrors() {
    _info "Configuring pacman mirrors (${REFLECTOR_COUNTRY})..."
    _echo_run reflector \
        -c "$REFLECTOR_COUNTRY" \
        -a "$REFLECTOR_AGE" \
        --protocol https \
        --sort rate \
        --download-timeout 60 \
        --save /etc/pacman.d/mirrorlist || return 1
}

_pacstrap_base_packages() {
    _info "Installing base packages with pacstrap (this may take a while)..."
    _echo_run pacstrap "$MNT" base base-devel || return 1
}

_generate_fstab() {
    _info "Generating fstab..."
    _echo_run genfstab -U "$MNT" >> "${MNT}/etc/fstab" || return 1
}

_setup_bootstrap() {
    _check_bootstrap_tools
    _propagate_rc $? || return $?

    _configure_live_mirrors
    _propagate_rc $? || return $?

    _pacstrap_base_packages
    _propagate_rc $? || return $?

    _generate_fstab
    _propagate_rc $? || return $?

    _info "Bootstrap completed"
    return 0
}

_build_mkinitcpio_hooks() {
    local hooks="base udev autodetect modconf kms keyboard keymap consolefont block"

    if [ "$ENCRYPTION_ENABLED" = true ]; then
        hooks+=" encrypt"
    fi

    hooks+=" lvm2 filesystems"

    if [ "$HIBERNATION_ENABLED" = true ]; then
        hooks+=" resume"
    fi

    hooks+=" fsck"
    echo "$hooks"
}

_configure_pacman_chroot() {
    local threads

    threads=$(nproc)
    _info "Setting ParallelDownloads to ${threads} in pacman.conf..."

    _chroot_run sed -i \
        -e "s/^#ParallelDownloads = .*/ParallelDownloads = ${threads}/" \
        -e "s/^ParallelDownloads = .*/ParallelDownloads = ${threads}/" \
        /etc/pacman.conf || return 1
}

_install_system_packages() {
    _info "Installing kernel, firmware, and system packages..."

    _chroot_run pacman -S --noconfirm \
        neovim \
        linux linux-headers linux-lts linux-lts-headers \
        linux-firmware sof-firmware \
        dosfstools lvm2 sudo cryptsetup btrfs-progs \
        vim man-db man-pages texinfo git xdg-user-dirs || return 1
}

_configure_mkinitcpio() {
    local hooks

    hooks=$(_build_mkinitcpio_hooks)
    _info "Configuring mkinitcpio (MODULES=btrfs, HOOKS=${hooks})..."

    _chroot_run sed -i 's/^MODULES=.*/MODULES=(btrfs)/' /etc/mkinitcpio.conf || return 1
    _chroot_run sed -i "s/^HOOKS=.*/HOOKS=(${hooks})/" /etc/mkinitcpio.conf || return 1

    if [ "$ENCRYPTION_ENABLED" != true ]; then
        _chroot_run sed -i \
            -e 's/^#FILES=.*/FILES=()/' \
            -e 's/^FILES=.*/FILES=()/' \
            /etc/mkinitcpio.conf || return 1
    fi
}

_install_grub_bootloader() {
    _info "Installing GRUB bootloader..."

    _chroot_run pacman -S --noconfirm grub efibootmgr || return 1
    _chroot_run grub-install --efi-directory=/boot/efi || return 1
}

_configure_encryption_boot() {
    local root_part_uuid root_lv_uuid home_part_uuid
    local grub_cmdline

    root_part_uuid=$(_get_uuid "$ROOT_PARTITION")
    root_lv_uuid=$(_get_uuid "$ROOT_LV")
    home_part_uuid=$(_get_uuid "$HOME_PARTITION")

    if [ -z "$root_part_uuid" ] || [ -z "$root_lv_uuid" ] || [ -z "$home_part_uuid" ]; then
        _error "Failed to resolve UUIDs for encrypted boot configuration"
        return 1
    fi

    _info "Configuring encrypted boot (GRUB, keyfiles, crypttab)..."

    _chroot_run mkdir -p /etc/luks_keys || return 1
    _chroot_run dd if=/dev/urandom of=/etc/luks_keys/root_keyfile.bin bs=512 count=8 status=none || return 1
    _chroot_run dd if=/dev/urandom of=/etc/luks_keys/home_keyfile.bin bs=512 count=8 status=none || return 1
    _chroot_run chmod 700 /etc/luks_keys || return 1
    _chroot_run chmod 000 /etc/luks_keys/root_keyfile.bin /etc/luks_keys/home_keyfile.bin || return 1

    _info "Adding LUKS keyfiles to encrypted partitions..."
    _log_interactive cryptsetup luksAddKey "$ROOT_PARTITION" "${MNT}/etc/luks_keys/root_keyfile.bin"
    cryptsetup luksAddKey "$ROOT_PARTITION" "${MNT}/etc/luks_keys/root_keyfile.bin" || return 1
    _log_interactive cryptsetup luksAddKey "$HOME_PARTITION" "${MNT}/etc/luks_keys/home_keyfile.bin"
    cryptsetup luksAddKey "$HOME_PARTITION" "${MNT}/etc/luks_keys/home_keyfile.bin" || return 1

    grub_cmdline="loglevel=3 quiet root=UUID=${root_lv_uuid} cryptdevice=UUID=${root_part_uuid}:luks_root"
    _chroot_run sed -i "s|^GRUB_CMDLINE_LINUX_DEFAULT=.*|GRUB_CMDLINE_LINUX_DEFAULT=\"${grub_cmdline}\"|" \
        /etc/default/grub || return 1

    _chroot_run sed -i \
        -e 's/^#FILES=.*/FILES=(\/etc\/luks_keys\/root_keyfile.bin)/' \
        -e 's/^FILES=.*/FILES=(\/etc\/luks_keys\/root_keyfile.bin)/' \
        /etc/mkinitcpio.conf || return 1

    printf '%s\t%s\t%s\t%s\n' \
        "luks_home" "UUID=${home_part_uuid}" "/etc/luks_keys/home_keyfile.bin" "luks,initramfs" \
        >> "${MNT}/etc/crypttab"

    return 0
}

_generate_boot_images() {
    _info "Generating GRUB config and initramfs images..."

    _chroot_run grub-mkconfig -o /boot/grub/grub.cfg || return 1
    _chroot_run grub-mkconfig -o /boot/efi/EFI/arch/grub.cfg || return 1
    _chroot_run mkinitcpio -p linux || return 1
    _chroot_run mkinitcpio -p linux-lts || return 1
    _chroot_run bash -c 'chmod 600 /boot/initramfs-linux* 2>/dev/null || true'
}

_setup_chroot_boot() {
    _info "Configuring bootable system inside chroot"

    _configure_pacman_chroot
    _propagate_rc $? || return $?

    _install_system_packages
    _propagate_rc $? "Failed to install system packages" || return $?

    _configure_mkinitcpio
    _propagate_rc $? || return $?

    _install_grub_bootloader
    _propagate_rc $? "Failed to install GRUB" || return $?

    if [ "$ENCRYPTION_ENABLED" = true ]; then
        _configure_encryption_boot
        _propagate_rc $? "Failed to configure encrypted boot" || return $?
    fi

    _generate_boot_images
    _propagate_rc $? "Failed to generate boot images" || return $?

    _info "Boot setup completed"
    return 0
}

# ============================================================================
# Localization, users, and desktop functions
# ============================================================================

_prompt_hostname() {
    _section "System Hostname"

    while true; do
        read -p "Enter hostname: " INSTALL_HOSTNAME

        if [[ $INSTALL_HOSTNAME =~ ^[a-zA-Z0-9][a-zA-Z0-9_-]*$ ]]; then
            _info "Hostname set to: $INSTALL_HOSTNAME"
            return 0
        fi

        _error "Invalid hostname. Use letters, numbers, underscore, or hyphen."
    done
}

_prompt_timezone() {
    local timezone

    _section "Timezone"
    _out "Default: $TIMEZONE"
    _out "Format: Region/City (e.g. Europe/Helsinki)"
    _out ""

    while true; do
        read -p "Enter timezone [${TIMEZONE}]: " timezone
        timezone=${timezone:-$TIMEZONE}

        if [ -f "/usr/share/zoneinfo/${timezone}" ] || [ -f "${MNT}/usr/share/zoneinfo/${timezone}" ]; then
            TIMEZONE=$timezone
            _info "Timezone set to: $TIMEZONE"
            return 0
        fi

        _error "Invalid timezone: $timezone"
    done
}

_configure_timezone() {
    _info "Setting timezone to $TIMEZONE..."

    _chroot_run ln -sf "/usr/share/zoneinfo/${TIMEZONE}" /etc/localtime || return 1
    _chroot_run hwclock --systohc || return 1
}

_configure_timesyncd() {
    _info "Configuring systemd-timesyncd..."

    _chroot_run sed -i \
        -e 's/^#NTP=.*/NTP=0.arch.pool.ntp.org 1.arch.pool.ntp.org 2.arch.pool.ntp.org 3.arch.pool.ntp.org/' \
        -e 's/^NTP=.*/NTP=0.arch.pool.ntp.org 1.arch.pool.ntp.org 2.arch.pool.ntp.org 3.arch.pool.ntp.org/' \
        -e 's/^#FallbackNTP=.*/FallbackNTP=0.pool.ntp.org 1.pool.ntp.org/' \
        -e 's/^FallbackNTP=.*/FallbackNTP=0.pool.ntp.org 1.pool.ntp.org/' \
        /etc/systemd/timesyncd.conf || return 1

    _chroot_run systemctl enable systemd-timesyncd.service || return 1
    _chroot_run timedatectl set-ntp true || return 1
}

_configure_locales() {
    _info "Configuring locales (en_US.UTF-8, fi_FI.UTF-8)..."

    _chroot_run sed -i \
        -e 's/^#en_US.UTF-8 UTF-8/en_US.UTF-8 UTF-8/' \
        -e 's/^#fi_FI.UTF-8 UTF-8/fi_FI.UTF-8 UTF-8/' \
        /etc/locale.gen || return 1
    _chroot_run locale-gen || return 1

    cat > "${MNT}/etc/locale.conf" <<'EOF'
LANG=en_US.UTF-8
LANGUAGE=en_US.UTF-8
LC_CTYPE=en_US.UTF-8
LC_NUMERIC=fi_FI.UTF-8
LC_TIME=fi_FI.UTF-8
LC_COLLATE=en_US.UTF-8
LC_MONETARY=fi_FI.UTF-8
LC_MESSAGES=en_US.UTF-8
LC_PAPER=fi_FI.UTF-8
LC_NAME=fi_FI.UTF-8
LC_ADDRESS=fi_FI.UTF-8
LC_TELEPHONE=fi_FI.UTF-8
LC_MEASUREMENT=fi_FI.UTF-8
LC_IDENTIFICATION=fi_FI.UTF-8
LC_ALL=
EOF

    _chroot_run mkdir -p /boot/grub/locale || return 1
    _chroot_run cp /usr/share/locale/en@quot/LC_MESSAGES/grub.mo /boot/grub/locale/en.mo || return 1
}

_configure_keyboard() {
    _info "Configuring console keyboard (${KEYMAP})..."

    cat > "${MNT}/etc/vconsole.conf" <<EOF
KEYMAP=${KEYMAP}
XKBLAYOUT=${KEYMAP}
XKBMODEL=pc106
XKBVARIANT=winkeys
EOF
}

_setup_localization() {
    _prompt_hostname
    _propagate_rc $? || return $?

    _prompt_timezone
    _propagate_rc $? || return $?

    _info "Configuring localization"

    _configure_timezone
    _propagate_rc $? || return $?

    _configure_timesyncd
    _propagate_rc $? || return $?

    _configure_locales
    _propagate_rc $? || return $?

    _configure_keyboard
    _propagate_rc $? || return $?

    _info "Localization completed"
    return 0
}

_configure_hostname() {
    _info "Setting hostname to $INSTALL_HOSTNAME..."
    printf '%s\n' "$INSTALL_HOSTNAME" > "${MNT}/etc/hostname"
}

_setup_root_password() {
    _section "Root Password"
    _info "Set password for root user..."

    _log_interactive arch-chroot "$MNT" passwd root
    arch-chroot "$MNT" passwd root || return 1
}

_enable_wheel_sudo() {
    _info "Granting sudo access to wheel group..."

    printf '%%wheel ALL=(ALL:ALL) ALL\n' > "${MNT}/etc/sudoers.d/wheel"
    _chroot_run chmod 440 /etc/sudoers.d/wheel || return 1
}

_remount_media_subvolume() {
    _info "Remounting Media subvolume for $INSTALL_USERNAME..."

    _echo_run mount --mkdir \
        -o "${BTRFS_MOUNT_OPTS},subvol=/@home/@media" \
        "$HOME_LV" "${MNT}/home/${INSTALL_USERNAME}/Media" || return 1

    _chroot_run chown "${INSTALL_USERNAME}:${INSTALL_USERNAME}" \
        "/home/${INSTALL_USERNAME}/Media" || return 1
}

_setup_admin_user() {
    local media_mount="${MNT}/home/${INSTALL_USERNAME}/Media"

    _info "Creating admin user: $INSTALL_USERNAME"

    if mountpoint -q "$media_mount"; then
        _echo_run umount "$media_mount" || return 1
    fi

    _chroot_run rm -rf "/home/${INSTALL_USERNAME}" || return 1
    _chroot_run useradd -m -G wheel -s /bin/bash "$INSTALL_USERNAME" || return 1

    _section "User Password: $INSTALL_USERNAME"
    _info "Set password for $INSTALL_USERNAME..."

    _log_interactive arch-chroot "$MNT" passwd "$INSTALL_USERNAME"
    arch-chroot "$MNT" passwd "$INSTALL_USERNAME" || return 1

    _enable_wheel_sudo || return 1
    _remount_media_subvolume || return 1

    return 0
}

_setup_users() {
    _info "Configuring hostname and users"

    _configure_hostname
    _propagate_rc $? || return $?

    _setup_root_password
    _propagate_rc $? "Failed to set root password" || return $?

    _setup_admin_user
    _propagate_rc $? "Failed to create admin user" || return $?

    _info "User setup completed"
    return 0
}

_enable_multilib() {
    if _chroot_run grep -q '^\[multilib\]' /etc/pacman.conf; then
        return 0
    fi

    _info "Enabling multilib repository..."
    _chroot_run sed -i '/^#\[multilib\]/,/^#Include/ s/^#//' /etc/pacman.conf || return 1
    _chroot_run pacman -Sy --noconfirm || return 1
}

_detect_cpu_microcode_package() {
    local vendor

    vendor=$(arch-chroot "$MNT" lscpu 2>/dev/null | awk -F: '/Vendor ID/ {gsub(/^[ \t]+/, "", $2); print $2; exit}')

    case $vendor in
        *AuthenticAMD*|*AMD*)
            echo "amd-ucode"
            ;;
        *GenuineIntel*|*Intel*)
            echo "intel-ucode"
            ;;
        *)
            echo ""
            ;;
    esac
}

_prompt_cpu_microcode_package() {
    local choice

    _out ""
    _out "CPU vendor not detected automatically."
    _out "[1] amd-ucode"
    _out "[2] intel-ucode"
    _out "[3] Skip microcode"

    while true; do
        read -p "Select microcode package [1-3]: " choice

        case $choice in
            1) echo "amd-ucode"; return 0 ;;
            2) echo "intel-ucode"; return 0 ;;
            3) echo ""; return 0 ;;
            *) _error "Invalid choice." ;;
        esac
    done
}

_detect_gpu_packages() {
    local vga_line

    vga_line=$(arch-chroot "$MNT" lspci -nn 2>/dev/null | grep -iE 'vga|3d|display' | head -1)

    if echo "$vga_line" | grep -qi 'nvidia'; then
        echo "nvidia nvidia-utils nvidia-lts"
    elif echo "$vga_line" | grep -qiE 'amd|ati|radeon'; then
        echo "mesa lib32-mesa libva-mesa-driver vulkan-radeon lib32-vulkan-radeon"
    elif echo "$vga_line" | grep -qi 'intel'; then
        echo "mesa lib32-mesa intel-media-driver"
    elif echo "$vga_line" | grep -qi 'vmware'; then
        echo "xf86-video-vmware"
    else
        echo ""
    fi
}

_prompt_gpu_packages() {
    local choice

    _out ""
    _out "GPU not detected automatically."
    _out "[1] AMD"
    _out "[2] Intel"
    _out "[3] Nvidia"
    _out "[4] VMware"
    _out "[5] Skip GPU drivers"

    while true; do
        read -p "Select GPU driver set [1-5]: " choice

        case $choice in
            1) echo "mesa lib32-mesa libva-mesa-driver vulkan-radeon lib32-vulkan-radeon"; return 0 ;;
            2) echo "mesa lib32-mesa intel-media-driver"; return 0 ;;
            3) echo "nvidia nvidia-utils nvidia-lts"; return 0 ;;
            4) echo "xf86-video-vmware"; return 0 ;;
            5) echo ""; return 0 ;;
            *) _error "Invalid choice." ;;
        esac
    done
}

_configure_reflector() {
    _info "Configuring reflector..."

    cat > "${MNT}/etc/xdg/reflector/reflector.conf" <<EOF
--save /etc/pacman.d/mirrorlist
--protocol https
--country ${REFLECTOR_COUNTRIES}
--latest 5
--sort age
EOF
}

_install_desktop_packages() {
    local microcode_pkg gpu_pkgs

    _info "Installing desktop environment and services..."

    _chroot_run pacman -S --noconfirm \
        networkmanager bluez bluez-utils reflector || return 1

    _configure_reflector || return 1

    _chroot_run systemctl enable NetworkManager || return 1
    _chroot_run systemctl enable bluetooth || return 1
    _chroot_run systemctl enable reflector.timer || return 1
    _chroot_run systemctl enable fstrim.timer || return 1

    microcode_pkg=$(_detect_cpu_microcode_package)
    if [ -z "$microcode_pkg" ]; then
        microcode_pkg=$(_prompt_cpu_microcode_package)
    fi

    if [ -n "$microcode_pkg" ]; then
        _info "Installing CPU microcode: $microcode_pkg"
        _chroot_run pacman -S --noconfirm "$microcode_pkg" || return 1
    else
        _warn "Skipping CPU microcode installation"
    fi

    _enable_multilib || return 1

    gpu_pkgs=$(_detect_gpu_packages)
    if [ -z "$gpu_pkgs" ]; then
        gpu_pkgs=$(_prompt_gpu_packages)
    fi

    if [ -n "$gpu_pkgs" ]; then
        _info "Installing GPU drivers: $gpu_pkgs"
        # shellcheck disable=SC2086
        _chroot_run pacman -S --noconfirm $gpu_pkgs || return 1
    else
        _warn "Skipping GPU driver installation"
    fi

    _chroot_run pacman -S --noconfirm \
        xorg plasma-desktop plasma-nm plasma-pa bluedevil \
        kscreen kcron ibus sddm kitty || return 1

    _chroot_run systemctl enable sddm || return 1

    return 0
}

_setup_desktop() {
    _install_desktop_packages
    _propagate_rc $? "Failed to install desktop packages" || return $?

    _generate_boot_images
    _propagate_rc $? "Failed to regenerate boot images" || return $?

    _info "Desktop setup completed"
    return 0
}

_finish_installation() {
    _section "Installation Complete"
    _out "Hostname:  $INSTALL_HOSTNAME"
    _out "User:      $INSTALL_USERNAME"
    _out "Timezone:  $TIMEZONE"
    _out ""
    _out "Post-install (after reboot):"
    _out "  cd ~/Workspace/linux-setup && ./setup arch"
    _out ""
    _out "See: instructions/install/arch-install.md (Post install steps)"
    _out "     and instructions/post-install/ (App configuration steps)"
    _out "=========================================="
    _out ""

    if ! _prompt_yes_no "Unmount ${MNT} and reboot now? (y/n): "; then
        _info "Skipping reboot. Remember to umount -R ${MNT} before rebooting manually."
        return 0
    fi

    local swap_device
    swap_device=$(_get_swap_device)

    if [ -n "$swap_device" ]; then
        _info "Disabling swap: $swap_device"
        swapoff "$swap_device" 2>/dev/null || true
    fi

    _info "Unmounting ${MNT}..."
    umount -R "$MNT" || {
        _error "Failed to unmount ${MNT}. Reboot manually when ready."
        return 1
    }

    _info "Rebooting..."
    reboot
}

# ============================================================================
# Main entry point
# ============================================================================

main() {
    _info "Arch Linux Installation Script"
    _info "Logging to: ${LOGFILE}"

    # Check if running as root
    if [ "$EUID" -ne 0 ]; then
        _error "This script must be run as root. Exiting."
        exit 1
    fi

    # Check if internet is available
    if ! ping -c 1 8.8.8.8 &> /dev/null; then
        _warn "Internet connection not available. Some features may not work."
    fi

    _run_phase "Disk setup" _setup_disk_configuration
    _exit_on_rc $?

    _out ""
    if _prompt_yes_no "Encrypt root and home partitions with LUKS2? (y/n): "; then
        ENCRYPTION_ENABLED=true
        _run_phase "Encryption setup" _setup_encryption
        _exit_on_rc $?
    else
        _info "Skipping encryption"
    fi

    _run_phase "LVM setup" _setup_lvm
    _exit_on_rc $?

    _run_phase "Filesystem setup" _setup_filesystems
    _exit_on_rc $?

    _run_phase "Bootstrap" _setup_bootstrap
    _exit_on_rc $?

    _run_phase "Boot setup" _setup_chroot_boot
    _exit_on_rc $?

    _run_phase "Localization" _setup_localization
    _exit_on_rc $?

    _run_phase "User setup" _setup_users
    _exit_on_rc $?

    _run_phase "Desktop setup" _setup_desktop
    _exit_on_rc $?

    _finish_installation

    exit 0
}

main "$@"
