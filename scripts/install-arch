#!/usr/bin/env bash

set -o pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
timestamp=$(date +"%Y-%m-%d_%H:%M:%S")
LOGFILE="../logs/${timestamp}_install-arch.log"

mkdir -p logs
exec 1> >(tee -a "$LOGFILE") 2>&1

# Configuration variables
ROOT_DEVICE=""
ROOT_SIZE=""
ROOT_SIZE_UNIT=""
HOME_DEVICE=""
HOME_SIZE=""
HOME_SIZE_UNIT=""
SWAP_TYPE=""
SWAP_SIZE=""
HIBERNATION_ENABLED=false

# Boot partition sizes (in GB)
BOOT_EFI_SIZE=1
BOOT_SIZE=4

# Device list (populated by _list_available_devices)
declare -a AVAILABLE_DEVICES

# ============================================================================
# Logging and output functions (reused from setup-arch)
# ============================================================================

_log() {
    local level="$1" msg="$2"
    printf "[%s] %s: %s\n" "$(date '+%Y-%m-%d %H:%M:%S')" "$level" "$msg"
}

_info() {
    _log "INFO" "$*"
    sleep 2
}

_info_long() {
    _log "INFO" "$*"
    sleep 3
}

_error() {
    _log "ERROR" "$*"
    sleep 3
}

_warn() {
    _log "WARN" "$*"
}

_echo_run() {
    _log "RUN" "$*"
    "$@" || { _error "Command failed: $*"; return 1; }
}

# ============================================================================
# Device discovery and display functions
# ============================================================================

_get_device_size() {
    local device=$1
    lsblk -bdn -o SIZE "$device" 2>/dev/null | head -1
}

_human_readable_size() {
    local bytes=$1
    numfmt --to=iec-i --suffix=B "$bytes" 2>/dev/null || {
        # Fallback if numfmt is not available
        echo "$(( bytes / 1024 / 1024 / 1024 ))GB"
    }
}

_list_available_devices() {
    _info_long "Scanning available block devices..."
    
    local -a devices
    
    # Get all block devices (excluding partitions and loops)
    while IFS= read -r line; do
        devices+=("$line")
    done < <(lsblk -dln -o NAME,SIZE,MODEL 2>/dev/null | grep -v loop)
    
    if [ ${#devices[@]} -eq 0 ]; then
        _error "No block devices found. Aborting."
        return 1
    fi
    
    # Store globally for use in selection function
    AVAILABLE_DEVICES=("${devices[@]}")
    
    echo ""
    echo "=========================================="
    echo "Available Block Devices"
    echo "=========================================="
    
    local idx=0
    while [ $idx -lt ${#devices[@]} ]; do
        echo "[$idx] ${devices[$idx]}"
        ((idx++))
    done
    
    echo ""
    return 0
}

_prompt_device_selection() {
    local prompt_msg=$1
    local device_var=$2
    local selected_device
    local device_name
    
    while true; do
        read -p "$prompt_msg" selected_device
        
        # Check, if input is an index number
        if [[ $selected_device =~ ^[0-9]+$ ]]; then
            if [ "$selected_device" -lt ${#AVAILABLE_DEVICES[@]} ]; then
                # Extract device name from the list entry (format: "NAME SIZE MODEL")
                device_name=$(echo "${AVAILABLE_DEVICES[$selected_device]}" | awk '{print $1}')
                # Change to /dev/xxx format
                selected_device="/dev/$device_name"
                eval "$device_var=$selected_device"
                _info "Selected device: $selected_device (Size: $(_human_readable_size $(_get_device_size "$selected_device")))"
                return 0
            else
                _error "Invalid index: $selected_device. Please enter a valid index."
                continue
            fi
        fi
        
        # Validate device exists (direct name or path input)
        #   - Device can be selected with both index and name/path
        if [ -b "/dev/$selected_device" ] || [ -b "$selected_device" ]; then
            # Normalize to /dev/xxx format
            if [[ ! "$selected_device" =~ ^/dev/ ]]; then
                selected_device="/dev/$selected_device"
            fi
            eval "$device_var=$selected_device"
            _info "Selected device: $selected_device (Size: $(_human_readable_size $(_get_device_size "$selected_device")))"
            return 0
        else
            _error "Invalid device or index: $selected_device. Please try again."
        fi
    done
}

# ============================================================================
# Partition sizing functions
# ============================================================================

_calculate_available_space() {
    local device=$1
    local partition_name=$2
    local device_size_bytes=$(_get_device_size "$device")
    local device_size_gb=$(( device_size_bytes / 1024 / 1024 / 1024 ))
    local reserved_space=0
    
    # Reserve boot partitions, if on same device as root
    if [ "$partition_name" = "ROOT" ]; then
        reserved_space=$(( BOOT_EFI_SIZE + BOOT_SIZE ))
        # Only reserve swap, if it's a partition (not LVM)
        if [ "$SWAP_TYPE" = "partition" ] && [ -n "$SWAP_SIZE" ]; then
            reserved_space=$(( reserved_space + SWAP_SIZE ))
        fi
    fi
    
    # Reserve boot partitions, swap, and root, if home is on same device as root
    if [ "$partition_name" = "HOME" ] && [ "$HOME_DEVICE" = "$ROOT_DEVICE" ]; then
        reserved_space=$(( reserved_space + BOOT_EFI_SIZE + BOOT_SIZE ))
        # Only reserve swap, if it's a partition (not LVM)
        if [ "$SWAP_TYPE" = "partition" ] && [ -n "$SWAP_SIZE" ]; then
            reserved_space=$(( reserved_space + SWAP_SIZE ))
        fi
        # Also reserve root partition size, if specified
        if [ -n "$ROOT_SIZE" ]; then
            reserved_space=$(( reserved_space + ROOT_SIZE ))
        fi
    fi
    
    local available_gb=$(( device_size_gb - reserved_space ))
    if [ $available_gb -lt 0 ]; then
        available_gb=0
    fi
    
    echo $available_gb
}

_prompt_partition_size() {
    local partition_name=$1
    local device=$2
    local device_size_bytes=$(_get_device_size "$device")
    local device_size_human=$(_human_readable_size $device_size_bytes)
    local available_gb=$(_calculate_available_space "$device" "$partition_name")
    local size_value
    local size_unit
    
    while true; do
        echo ""
        echo "Configuring size for $partition_name on $device"
        echo "  Total device size: ~$device_size_human"
        echo "  Available space:   ~${available_gb}GB"
        
        if [ "$partition_name" = "ROOT" ]; then
            if [ "$SWAP_TYPE" = "partition" ]; then
                echo "  Reserved: Boot EFI (${BOOT_EFI_SIZE}GB) + Boot (${BOOT_SIZE}GB) + Swap (${SWAP_SIZE}GB)"
            else
                echo "  Reserved: Boot EFI (${BOOT_EFI_SIZE}GB) + Boot (${BOOT_SIZE}GB)"
            fi
        fi
        
        if [ "$partition_name" = "HOME" ] && [ "$HOME_DEVICE" = "$ROOT_DEVICE" ]; then
            if [ "$SWAP_TYPE" = "partition" ]; then
                echo "  Reserved: Boot EFI (${BOOT_EFI_SIZE}GB) + Boot (${BOOT_SIZE}GB) + Swap (${SWAP_SIZE}GB) + ROOT (${ROOT_SIZE}${ROOT_SIZE_UNIT})"
            else
                echo "  Reserved: Boot EFI (${BOOT_EFI_SIZE}GB) + Boot (${BOOT_SIZE}GB) + ROOT (${ROOT_SIZE}${ROOT_SIZE_UNIT})"
            fi
        fi
        
        read -p "Enter size (e.g., '100G' for 100GB or 'all' to use all available space): " size_input
        
        if [ "$size_input" = "all" ]; then
            eval "${partition_name}_SIZE=all"
            eval "${partition_name}_SIZE_UNIT=all"
            _info "$partition_name will use all available space"
            return 0
        fi
        
        # Validate size format (must end with G, T, M, etc.)
        if [[ $size_input =~ ^[0-9]+[GMT]$ ]]; then
            eval "${partition_name}_SIZE=${size_input%?}"
            eval "${partition_name}_SIZE_UNIT=${size_input: -1}"
            _info "$partition_name size set to: $size_input"
            return 0
        else
            _error "Invalid format. Please use format like '100G', '1T', '512M', or 'all'"
        fi
    done
}

# ============================================================================
# Swap configuration functions
# ============================================================================

_get_total_ram() {
    local ram_kb
    ram_kb=$(grep MemTotal /proc/meminfo | awk '{print $2}')
    # Convert KB to GB - round to nearest GB
    echo $(( (ram_kb + 524287) / 1048576 ))
}

_prompt_swap_type() {
    local swap_type
    
    echo ""
    echo "=========================================="
    echo "Swap Configuration"
    echo "=========================================="
    echo ""
    
    while true; do
        echo "Select swap type:"
        echo "[1] Swap as partition"
        echo "[2] Swap as LVM logical volume"
        read -p "Enter choice [1 or 2]: " swap_type
        
        case $swap_type in
            1)
                SWAP_TYPE="partition"
                _info "Swap will be created as a partition"
                return 0
                ;;
            2)
                SWAP_TYPE="lvm"
                _info "Swap will be created as an LVM logical volume"
                return 0
                ;;
            *)
                _error "Invalid choice. Please enter 1 or 2."
                ;;
        esac
    done
}

_prompt_hibernation() {
    local response
    
    echo ""
    read -p "Do you need hibernation support? (y/n): " response
    
    if [[ $response =~ ^[Yy]$ ]]; then
        HIBERNATION_ENABLED=true
        _info "Hibernation support enabled"
    else
        HIBERNATION_ENABLED=false
        _info "Hibernation support disabled"
    fi
}

_calculate_sqrt() {
    local num=$1
    local sqrt=0
    local bit=1
    
    # Find the highest bit
    while [ $((bit * bit)) -le $num ]; do
        bit=$((bit * 2))
    done
    bit=$((bit / 2))
    
    # Binary search for square root
    while [ $bit -gt 0 ]; do
        if [ $(((sqrt + bit) * (sqrt + bit))) -le $num ]; then
            sqrt=$((sqrt + bit))
        fi
        bit=$((bit / 2))
    done
    
    echo $sqrt
}

_calculate_swap_size() {
    local ram_gb=$(_get_total_ram)
    local swap_gb
    local sqrt_ram
    
    sqrt_ram=$(_calculate_sqrt $ram_gb)
    
    if [ "$HIBERNATION_ENABLED" = true ]; then
        # For hibernation: RAM + sqrt(RAM)
        swap_gb=$(( ram_gb + sqrt_ram ))
        _info "Swap size for hibernation: ${swap_gb}GB (RAM: ${ram_gb}GB + sqrt(RAM): ${sqrt_ram}GB)"
    else
        # For non-hibernation: sqrt(RAM), minimum 2GB
        swap_gb=$sqrt_ram
        if [ $swap_gb -lt 2 ]; then
            swap_gb=2
        fi
        _info "Swap size without hibernation: sqrt(RAM): ${swap_gb}GB"
    fi
    
    SWAP_SIZE=$swap_gb
}

# ============================================================================
# Validation and summary functions
# ============================================================================

_validate_devices() {
    if [ -z "$ROOT_DEVICE" ]; then
        _error "Root device not selected"
        return 1
    fi
    
    if [ -z "$HOME_DEVICE" ]; then
        _error "Home device not selected"
        return 1
    fi
    
    if [ "$ROOT_DEVICE" = "$HOME_DEVICE" ]; then
        _info "Root and home will be on the same device"
    else
        _info "Root and home will be on separate devices"
    fi
    
    return 0
}

_print_configuration_summary() {
    local root_display
    local home_display
    
    # Display root and home partition size even, when all is selected 
    if [ "$ROOT_SIZE_UNIT" = "all" ]; then
        local available_root=$(_calculate_available_space "$ROOT_DEVICE" "ROOT")
        root_display="${available_root}GB (all available)"
    else
        root_display="${ROOT_SIZE}${ROOT_SIZE_UNIT}"
    fi
    
    if [ "$HOME_SIZE_UNIT" = "all" ]; then
        local available_home=$(_calculate_available_space "$HOME_DEVICE" "HOME")
        home_display="${available_home}GB (all available)"
    else
        home_display="${HOME_SIZE}${HOME_SIZE_UNIT}"
    fi
    
    echo ""
    echo "=========================================="
    echo "Installation Configuration Summary"
    echo "=========================================="
    echo ""
    echo "Root Device:              $ROOT_DEVICE"
    echo "Root Partition Size:      $root_display"
    echo ""
    echo "Home Device:              $HOME_DEVICE"
    echo "Home Partition Size:      $home_display"
    echo ""
    echo "Swap Type:                $SWAP_TYPE"
    echo "Swap Size:                ${SWAP_SIZE}GB"
    echo "Hibernation Support:      $([ "$HIBERNATION_ENABLED" = true ] && echo "Yes" || echo "No")"
    echo ""
    echo "=========================================="
    echo ""
}

_confirm_configuration() {
    local response
    
    while true; do
        read -p "Do you want to proceed with this configuration? (yes/no): " response
        
        case $response in
            yes)
                _info "Configuration confirmed"
                return 0
                ;;
            no)
                _error "Configuration cancelled by user"
                return 1
                ;;
            *)
                _warn "Please enter 'yes' or 'no'"
                ;;
        esac
    done
}

# ============================================================================
# Disk setup phase
# ============================================================================

_setup_disk_configuration() {
    _info_long "Starting Arch Linux disk setup configuration"
    
    # List available devices
    _list_available_devices || return 1
    
    # Select root device
    _prompt_device_selection "Enter root device index number or name (e.g., 1, 2 or sda, nvme0n1): " ROOT_DEVICE || return 1
    
    # Select home device
    _prompt_device_selection "Enter home device index number or name (e.g., 1, 2 or sda, nvme0n1, or same as root): " HOME_DEVICE || return 1
    
    # Configure swap BEFORE partition sizes (so available space can be calculated)
    _prompt_swap_type || return 1
    _prompt_hibernation
    _calculate_swap_size
    
    # Configure root partition size (accounting for boot and swap)
    _prompt_partition_size "ROOT" "$ROOT_DEVICE" || return 1
    
    # Configure home partition size (accounting for reserved space)
    _prompt_partition_size "HOME" "$HOME_DEVICE" || return 1
    
    # Validate and display summary
    _validate_devices || return 1
    _print_configuration_summary
    _confirm_configuration || return 1
    
    _info_long "Disk configuration phase completed successfully"
    _log "INFO" "Configuration saved to: $LOGFILE"
    
    return 0
}

# ============================================================================
# Main entry point
# ============================================================================

main() {
    _info_long "Arch Linux Installation Script - Disk Setup Phase"
    
    # Check if running as root
    if [ "$EUID" -ne 0 ]; then
        _error "This script must be run as root. Exiting."
        exit 1
    fi
    
    # Check if internet is available
    if ! ping -c 1 8.8.8.8 &> /dev/null; then
        _warn "Internet connection not available. Some features may not work."
    fi
    
    _setup_disk_configuration || {
        _error "Disk setup configuration failed. Exiting."
        exit 1
    }
    
    echo ""
    echo "=========================================="
    echo "Next Steps:"
    echo "=========================================="
    echo "1. Review the configuration summary above"
    echo "2. Once finalized, proceed with:"
    echo "   - Partition creation (gdisk)"
    echo "   - Encryption setup (cryptsetup)"
    echo "   - Logical volume creation (lvm2)"
    echo "   - Filesystem creation and mounting"
    echo ""
    echo "For more details, see: instructions/install/arch-install.md"
    echo "=========================================="
    
    exit 0
}

main "$@"
